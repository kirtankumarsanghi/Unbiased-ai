{
  "title": "EquiAudit Monitoring",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(equiaudit_http_requests_total[5m]))"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(equiaudit_http_responses_total{status=~\"5..\"}[5m]))"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "P95 Request Latency",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(equiaudit_http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}