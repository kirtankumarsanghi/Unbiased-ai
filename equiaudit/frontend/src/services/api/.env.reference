VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=EquiAudit
VITE_APP_VERSION=4.2.0
# Set to true so auth works without a running backend server
VITE_ENABLE_MOCK_DATA=true

# AI Provider Configuration (works without backend!)
# The system tries providers in order: Gemini → OpenAI → Built-in Intelligence

# Option 1: Google Gemini (FREE tier available!)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash

# Option 2: OpenAI (requires paid API key)
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# Note: If no API keys are set, the system uses built-in intelligent responses
# that provide balanced, unbiased analysis without any external API calls.
